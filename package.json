{
  "name": "clearforge-daily-ai-brief-builder",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "description": "Clearforge automated daily AI news research, validation, evergreen learning, audience-fit optimisation, media and distribution system.",
  "scripts": {
    "daily": "bash scripts/run-fresh-daily-with-event-retry.sh",
    "angle:alternate": "node src/reangle-daily.mjs",
    "draft": "node src/generate-daily-brief.mjs",
    "novelty:event": "node src/check-event-novelty.mjs",
    "social:optimise": "node src/optimise-social-audience-fit.mjs",
    "feature": "node src/generate-full-feature.mjs",
    "evergreen": "node src/generate-evergreen-explainer.mjs",
    "podcast:daily": "node src/generate-daily-podcast-script.mjs",
    "opportunity:weekly": "node src/generate-weekly-opportunity.mjs",
    "newsletter:weekly": "node src/generate-weekly-newsletter.mjs",
    "validate:auto": "bash scripts/validate-with-report.sh",
    "media:ai": "node src/generate-ai-media.mjs",
    "syndicate:dev": "node src/post-feature-to-dev.mjs",
    "export:approved": "node src/export-approved-bundle.mjs",
    "build:site": "node src/build-site.mjs && node src/build-evergreen-guides.mjs && node scripts/hide-podcast-rss-link.mjs && node scripts/add-control-kit-product.mjs",
    "check": "node src/check-approval.mjs"
  },
  "dependencies": {
    "openai": "latest"
  },
  "devDependencies": {}
}
